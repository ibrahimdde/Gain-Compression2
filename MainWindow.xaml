<Window x:Class="FfmpegWrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gain Compression" Height="620" Width="600"
        WindowStartupLocation="CenterScreen" Background="#f3f4f6" 
        Loaded="Window_Loaded" AllowDrop="True" Drop="Pencere_DosyaBirakildiginda">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Dosya İşlemleri -->
        <GroupBox x:Name="grpFileOps" Header="1. Dosya Seçimi" Grid.Row="0" Margin="0,0,0,15" Padding="10" FontWeight="Bold">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtInputFile" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <Button Content="Video Seç" Grid.Column="1" Width="100" Height="25" Click="BtnSelectFile_Click" FontWeight="Normal"/>
                </Grid>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtOutputDir" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <Button Content="Çıktı Klasörü Seç" Grid.Column="1" Width="100" Height="25" Click="BtnSelectOutputDir_Click" FontWeight="Normal"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Profil İşlemleri -->
        <GroupBox x:Name="grpProfileOps" Header="2. Sıkıştırma Ayarları (CRUD)" Grid.Row="1" Margin="0,0,0,15" Padding="10" FontWeight="Bold">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Kayıtlı Profil:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Normal"/>
                    <ComboBox x:Name="cmbProfiles" Grid.Column="1" Margin="0,0,10,0" SelectionChanged="CmbProfiles_SelectionChanged" DisplayMemberPath="ProfilAdi" FontWeight="Normal"/>
                    <Button Content="Yeni" Grid.Column="2" Width="40" Margin="0,0,5,0" Click="BtnNewProfile_Click" FontWeight="Normal"/>
                    <Button Content="Kaydet" Grid.Column="3" Width="60" Margin="0,0,5,0" Click="BtnSaveProfile_Click" FontWeight="Normal"/>
                    <Button Content="Sil" Grid.Column="4" Width="40" Click="BtnDeleteProfile_Click" Foreground="Red" FontWeight="Normal"/>
                </Grid>

                <UniformGrid Columns="2" Rows="6" TextElement.FontWeight="Normal">
                    <TextBlock Text="Profil Adı:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtProfileName" Margin="5" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Çözünürlük (Örn: 1920x1080):" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtResolution" Margin="5" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Bitrate (kbps - Örn: 2000):" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtBitrate" Margin="5" VerticalContentAlignment="Center"/>

                    <TextBlock Text="FPS (Örn: 30):" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtFps" Margin="5" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Video Formatı (Codec):" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbCodec" Margin="5" SelectedIndex="0">
                        <ComboBoxItem Content="H264 (libx264)"/>
                        <ComboBoxItem Content="H265 (libx265)"/>
                        <ComboBoxItem Content="AV1 (libaom-av1)"/>
                    </ComboBox>

                    <TextBlock Text="Sıkıştırma Hızı (Preset):" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbPreset" Margin="5" SelectedIndex="2">
                        <ComboBoxItem Content="Çok Hızlı (ultrafast)"/>
                        <ComboBoxItem Content="Hızlı (fast)"/>
                        <ComboBoxItem Content="Normal (medium)"/>
                        <ComboBoxItem Content="Yavaş (slow)"/>
                    </ComboBox>
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <!-- Başlatma Butonu -->
        <Button x:Name="btnStart" Content="🚀 SIKIŞTIRMAYI BAŞLAT" Grid.Row="2" Height="45" Background="#3b82f6" Foreground="White" FontWeight="Bold" FontSize="15" Click="BtnStart_Click" Margin="0,0,0,15">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <!-- Progress -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtTime" Text="Geçen Süre: 00:00:00" Grid.Column="0" FontWeight="Bold"/>
                <TextBlock x:Name="txtPercentage" Text="%0.0" Grid.Column="1" HorizontalAlignment="Right" FontWeight="Bold"/>
            </Grid>
            <ProgressBar x:Name="progressBar" Height="25" Minimum="0" Maximum="100" Value="0" Foreground="#22c55e">
                 <ProgressBar.Resources>
                     <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                     </Style>
                 </ProgressBar.Resources>
            </ProgressBar>
        </StackPanel>

        <!-- Log Area -->
        <GroupBox Header="İşlem Geçmişi" Grid.Row="4" Padding="5" FontWeight="Bold">
            <TextBox x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Background="#1e293b" Foreground="#e2e8f0" FontWeight="Normal"/>
        </GroupBox>

    </Grid>
</Window>
